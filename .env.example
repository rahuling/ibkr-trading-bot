# IB Gateway credentials (passed to the Docker container)
IBKR_USERNAME=your_ibkr_username
IBKR_PASSWORD=your_ibkr_password

# paper or live — controls which gateway mode the Docker container starts in
# Keep as "paper" until the bot is fully validated.
TRADING_MODE=paper

# IB Gateway connection — defaults match docker-compose.yml (127.0.0.1:4002)
# Only change these if you're running the gateway on a different host/port.
IB_GATEWAY_HOST=127.0.0.1
IB_GATEWAY_PORT=4002
IB_CLIENT_ID=1

# Telegram — get the bot token from @BotFather, your user ID from @userinfobot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_ALLOWED_USER_IDS=123456789
# Multiple users: TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
