# Copy this file to .env and fill in your values.
# .env is in .gitignore and must NEVER be committed.

# IBKR credentials (used by IB Gateway Docker container)
IBKR_USERNAME=your_ibkr_username
IBKR_PASSWORD=your_ibkr_password

# paper or live — change to 'live' only after full paper validation
TRADING_MODE=paper

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWXyz

# Your Telegram user ID(s) — comma-separated, no spaces
# Get yours by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USER_IDS=123456789

# IB Gateway connection (leave as-is for local/VPS Docker setup)
IB_GATEWAY_HOST=127.0.0.1
IB_GATEWAY_PORT=4002
IB_CLIENT_ID=1
